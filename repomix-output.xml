  .dh-skeleton {
    background: linear-gradient(90deg,
      oklch(0.72 0.19 149 / 0.05) 25%, oklch(0.72 0.19 149 / 0.12) 50%, oklch(0.72 0.19 149 / 0.05) 75%);
    background-size: 200% 100%; animation: dh-shimmer 1.6s infinite;
