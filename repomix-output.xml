        .populate('reportedUserId')
        .populate('reportedBy')
        .sort({ createdAt: -1 })
        .skip(skip)
        .limit(limit),

      UserReportModel.countDocuments({
        status: 'pending',
      }),
    ]);

    return {
      reports,
      total,
    };
  },
